# =============================================================================
# APIMarketplace / KineticAPI — environment variables
# Copy to .env.local and fill in secrets. Never commit .env.local.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (required for app + middleware)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Server-side alias (some routes / Edge functions use SUPABASE_URL)
SUPABASE_URL=https://your-project.supabase.co

# Optional: SSO / org management (Supabase Management API)
SUPABASE_MANAGEMENT_API_TOKEN=

# Optional: deployment / tooling (discovery scripts)
SUPABASE_PROJECT_ID=
NEXT_PUBLIC_SUPABASE_PROJECT_ID=

# -----------------------------------------------------------------------------
# Site & branding (public)
# -----------------------------------------------------------------------------
# Production: https://your-domain.com — local dev default matches npm run dev (port 3020)
NEXT_PUBLIC_SITE_URL=http://localhost:3020
# Alternate base URL (e.g. marketing site vs app); optional
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_PLATFORM_NAME=APIMarketplace

# Social / marketing (Footer links; omit to hide)
NEXT_PUBLIC_TWITTER_URL=
NEXT_PUBLIC_GITHUB_URL=
NEXT_PUBLIC_LINKEDIN_URL=

# Landing / demos
NEXT_PUBLIC_DEMO_VIDEO_URL=
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-org/enterprise-demo
# Landing: 'true' = gradient band layout; omit or 'false' = block layout
# NEXT_PUBLIC_LANDING_GRADIENT_BANDS=false

# -----------------------------------------------------------------------------
# Kong API Gateway (when ENABLE_KONG=true)
# -----------------------------------------------------------------------------
ENABLE_KONG=false
KONG_ADMIN_URL=http://localhost:8001
KONG_PROXY_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Legacy name sometimes used in tooling; prefer NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_...

# -----------------------------------------------------------------------------
# AI (Anthropic = Playground / workflows; OpenAI = embeddings + semantic search)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_...
RESEND_WEBHOOK_SECRET=
# From address for transactional email (Next.js app)
EMAIL_FROM=noreply@example.com
# Edge function developer-nurture uses this name; can match EMAIL_FROM
RESEND_FROM_EMAIL=noreply@example.com

# -----------------------------------------------------------------------------
# Redis (optional caching)
# -----------------------------------------------------------------------------
ENABLE_CACHING=true
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Feature toggles (documented; wire-up may vary by route)
# -----------------------------------------------------------------------------
ENABLE_BILLING=true
ENABLE_AI_PLAYGROUND=true
ENABLE_WORKFLOWS=true

# -----------------------------------------------------------------------------
# GitHub OAuth (codebase analytics / integrations)
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Cron (Vercel Cron / external scheduler — Bearer or x-cron-secret)
# -----------------------------------------------------------------------------
CRON_SECRET=your-cron-secret

# Data retention: drop api_requests_log partitions older than N months (default 12)
API_REQUESTS_LOG_RETENTION_MONTHS=12

# -----------------------------------------------------------------------------
# Optional integrations & keys
# -----------------------------------------------------------------------------
# CLI / marketplace tooling (when used)
APIMP_KEY=
# Landing TechShowcase demo (optional)
LUKEAPI_KEY=
# Admin readiness / validation context file path
VALIDATION_CONTEXT_PATH=./validation-context.json

# -----------------------------------------------------------------------------
# Error monitoring (Sentry)
# -----------------------------------------------------------------------------
SENTRY_DSN=https://your-dsn@o0.ingest.sentry.io/0
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
# Build-time: upload source maps (CI / local release)
SENTRY_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# E2E / Playwright (local + CI)
# -----------------------------------------------------------------------------
# App URL under test (default 3020 matches npm run dev)
BASE_URL=http://localhost:3020
PLAYWRIGHT_TEST_BASE_URL=http://localhost:3020
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=test-password
TEST_ADMIN_EMAIL=admin@example.com
TEST_ADMIN_PASSWORD=admin-password

# -----------------------------------------------------------------------------
# Node / Next.js / CI (usually set automatically; document only)
# -----------------------------------------------------------------------------
NODE_ENV=development
ANALYZE=
CI=
NEXT_RUNTIME=

# Read-only (npm; documented for tooling)
npm_package_version=1.0.0
