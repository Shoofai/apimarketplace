{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "crons": [
    {"path": "/api/cron/generate-invoices",        "schedule": "0 6 1 * *"},
    {"path": "/api/cron/compute-sla",              "schedule": "*/15 * * * *"},
    {"path": "/api/cron/process-dunning",          "schedule": "0 8 * * *"},
    {"path": "/api/cron/retry-webhooks",           "schedule": "*/10 * * * *"},
    {"path": "/api/cron/process-nurture",          "schedule": "0 * * * *"},
    {"path": "/api/cron/check-api-health",         "schedule": "*/5 * * * *"},
    {"path": "/api/cron/notify-expiring-keys",     "schedule": "0 9 * * *"},
    {"path": "/api/cron/process-gdpr-deletions",   "schedule": "0 2 * * *"},
    {"path": "/api/cron/process-retention",        "schedule": "0 3 * * 0"},
    {"path": "/api/cron/refresh-mvs",              "schedule": "0 4 * * *"}
  ]
}
