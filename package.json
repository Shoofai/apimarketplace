{
  "name": "lukeapi",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3020 --turbo",
    "build": "next build",
    "build:clean": "rm -rf .next && npm run build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:regression": "playwright test --config=playwright.regression.config.ts; tsx scripts/write-regression-summary.ts",
    "test:e2e:regression:report": "tsx scripts/write-regression-summary.ts",
    "load:marketplace": "k6 run tests/load/marketplace.js",
    "load:dashboard": "k6 run tests/load/dashboard.js",
    "analyze": "ANALYZE=true next build",
    "create-test-users": "tsx scripts/create-test-users.ts",
    "seed-public-apis": "tsx src/lib/seed/seed-public-apis.ts",
    "seed-programmableweb-bulk": "tsx src/lib/seed/seed-programmableweb-bulk.ts",
    "scanner:build": "npm run build --prefix prod-readiness-scanner",
    "audit:prod": "node prod-readiness-scanner/dist/cli/index.js scan --project . --out . --format json,md --fail-on CRITICAL",
    "audit:prod:strict": "node prod-readiness-scanner/dist/cli/index.js scan --project . --out . --format json,md --fail-on HIGH",
    "deployment-check": "tsx scripts/deployment-check.ts",
    "preflight": "tsx scripts/preflight.ts",
    "blog:auth": "npx tsx blog-import/import.ts --auth",
    "blog:import": "npx tsx blog-import/import.ts",
    "blog:import:dry": "npx tsx blog-import/import.ts --dry-run",
    "blog:import:force": "npx tsx blog-import/import.ts --force"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@apidevtools/swagger-parser": "^10.1.0",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@google-cloud/local-auth": "^3.0.1",
    "@hookform/resolvers": "^3.9.1",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^10.43.0",
    "@stripe/react-stripe-js": "^5.6.0",
    "@stripe/stripe-js": "^8.7.0",
    "@supabase/ssr": "^0.6.0",
    "@supabase/supabase-js": "^2.48.0",
    "@tanstack/react-query": "^5.66.1",
    "@uiw/react-codemirror": "^4.24.3",
    "bcryptjs": "^2.4.3",
    "chalk": "^4.1.2",
    "chart.js": "^4.4.8",
    "class-variance-authority": "^0.7.1",
    "cli-progress": "^3.12.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.4",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.34.3",
    "googleapis": "^171.4.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.468.0",
    "nanoid": "^5.0.9",
    "next": "^15.5.13",
    "next-themes": "^0.4.6",
    "pino": "^9.6.0",
    "pino-pretty": "^11.0.0",
    "react": "^19.0.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "react-international-phone": "^4.7.0",
    "react-resizable-panels": "^2.1.7",
    "react-split": "^2.0.14",
    "react-syntax-highlighter": "^16.1.1",
    "reactflow": "^11.11.4",
    "redis": "^4.7.0",
    "resend": "^6.9.4",
    "sonner": "^2.0.7",
    "stripe": "^17.5.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.49.1",
    "@tailwindcss/typography": "^0.5.15",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.24",
    "dotenv": "^16.4.7",
    "eslint": "^9",
    "eslint-config-next": "15.1.4",
    "jsdom": "^25.0.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^4.0.18",
    "webpack-bundle-analyzer": "^4.10.2"
  }
}
